{
  "id": "foundry-forge-mcp",
  "title": "Foundry Forge MCP",
  "description": "Fork of adambdooley/foundry-vtt-mcp adding direct actor image (Forge URL) and embedded-document CRUD (add/update/remove items) for MCP-driven automation. Original module connects Foundry VTT to AI models via MCP; this fork extends the write surface for NPC portrait sync and stat-block patching workflows.",
  "version": "0.1.12",
  "compatibility": {
    "minimum": "13",
    "verified": "13",
    "maximum": "13"
  },
  "authors": [
    {
      "name": "Ben Barrey",
      "url": "https://github.com/bdbarrey"
    },
    {
      "name": "Adam Dooley (original)",
      "email": "adambriandooley@gmail.com",
      "url": "https://github.com/adambdooley"
    }
  ],
  "url": "https://github.com/bdbarrey/foundry-forge-mcp",
  "bugs": "https://github.com/bdbarrey/foundry-forge-mcp/issues",
  "changelog": "https://github.com/bdbarrey/foundry-forge-mcp/releases",
  "readme": "https://github.com/bdbarrey/foundry-forge-mcp/blob/master/README.md",
  "license": "https://github.com/bdbarrey/foundry-forge-mcp/blob/master/LICENSE",
  "esmodules": [
    "dist/main.js"
  ],
  "styles": [
    "styles/module.css",
    "styles/enhanced-creature-index.css"
  ],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    }
  ],
  "socket": true,
  "manifest": "https://github.com/bdbarrey/foundry-forge-mcp/releases/latest/download/module.json",
  "download": "https://github.com/bdbarrey/foundry-forge-mcp/releases/latest/download/foundry-forge-mcp.zip",
  "protected": false,
  "coreTranslation": false,
  "library": false,
  "flags": {
    "hotReload": {
      "extensions": ["css", "hbs", "json"],
      "paths": ["scripts", "styles", "templates", "lang"]
    }
  }
}
